# ============================================
# 依赖和构建产物
# ============================================
node_modules/
dist/

# ============================================
# Python 缓存
# ============================================
__pycache__/
*.pyc
*.pyo

# ============================================
# 压缩包
# ============================================
*.7z
*.zip
*.tar.gz

# ============================================
# Go 编译产物 / 二进制
# ============================================
ism_server_user/ism_server*
ism_server_user/ISMServer*

# ============================================
# 数据库备份
# ============================================
*.db.bak*
*.sqlite.bak*

# ============================================
# 项目级备份 (scripts/backup_project.py 产物)
#   - tables/ 为完整逐表导出, 含 18M 的 display_model_layer, 不入 git
#     (display 画面可由 build_ncc_dashboard.py 重建)
#   - manifest.json (~6K) + minimal_bundle.json (~112K) 体积小,
#     纳入 git 以便云端恢复 & 变更可追溯
# ============================================
backups/*/tables/

# ============================================
# 日志文件
# ============================================
logs/
*.log

# ============================================
# IDE 和编辑器
# ============================================
.idea/
.vscode/
*.swp
*.swo
*~

# ============================================
# 操作系统
# ============================================
.DS_Store
Thumbs.db

# ============================================
# 环境配置（含敏感信息）
# ============================================
.env
.env.local
.env.*.local

# ============================================
# 会话和临时文件
# ============================================
data/sessionon/
data/upload/
tmp/
temp/
